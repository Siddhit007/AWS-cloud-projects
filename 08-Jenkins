📂 Sample Jenkins Pipeline
pipeline {
    agent { label 'Linux-slave' }

    stages {
        stage('Build') {
            steps {
                echo 'Building application...'
            }
        }

        stage('Deploy to Tomcat') {
            steps {
                sh 'cp app.war /opt/tomcat/webapps/'
            }
        }
    }
}
